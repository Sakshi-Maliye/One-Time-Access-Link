pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/your-repo/one-time-link-api.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t one-time-link-api .'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker run -d -p 8080:8080 one-time-link-api'
            }
        }
    }
}